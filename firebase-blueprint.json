{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user subscription, phone, and password.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "shortId": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "trialStartDate": { "type": "string", "format": "date-time" },
        "isActiveUntil": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phone", "password", "role", "shortId", "uid"]
    },
    "ActivationKey": {
      "title": "Activation Key",
      "description": "Keys generated by admin to activate user accounts.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "durationMonths": { "type": "number" }
      },
      "required": ["key", "isUsed", "createdAt"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Tracks global usage metrics like AI requests.",
      "type": "object",
      "properties": {
        "aiRequestsCount": { "type": "number" },
        "lastResetDate": { "type": "string", "format": "date-time" }
      },
      "required": ["aiRequestsCount"]
    }
  },
  "firestore": {
    "/users/{phone}": {
      "schema": "User",
      "description": "User profiles and subscription status."
    },
    "/activationKeys/{key}": {
      "schema": "ActivationKey",
      "description": "Keys for account activation."
    },
    "/stats/global": {
      "schema": "GlobalStats",
      "description": "Global usage tracking."
    }
  }
}
